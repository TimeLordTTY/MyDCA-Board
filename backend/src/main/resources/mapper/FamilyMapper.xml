<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.timelordtty.dca.mapper.FamilyMapper">

    <resultMap id="BaseResultMap" type="com.timelordtty.dca.model.Family">
        <id column="id" property="id"/>
        <result column="family_code" property="familyCode"/>
        <result column="family_name" property="familyName"/>
        <result column="admin_user_id" property="adminUserId"/>
        <result column="is_active" property="isActive"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM families WHERE id = #{id}
    </select>

    <select id="selectByCode" resultMap="BaseResultMap">
        SELECT * FROM families WHERE family_code = #{familyCode}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO families (family_code, family_name, admin_user_id, is_active, created_at, updated_at)
        VALUES (#{familyCode}, #{familyName}, #{adminUserId}, #{isActive}, NOW(), NOW())
    </insert>

    <update id="update">
        UPDATE families
        SET family_name = #{familyName},
            is_active = #{isActive},
            updated_at = NOW()
        WHERE id = #{id}
    </update>

</mapper>

