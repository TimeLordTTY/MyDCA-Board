<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.timelordtty.dca.mapper.OrderFundingLineMapper">

    <resultMap id="BaseResultMap" type="com.timelordtty.dca.model.OrderFundingLine">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="order_id" property="orderId" jdbcType="VARCHAR"/>
        <result column="line_no" property="lineNo" jdbcType="INTEGER"/>
        <result column="account_id" property="accountId" jdbcType="BIGINT"/>
        <result column="amount" property="amount" jdbcType="DECIMAL"/>
        <result column="currency" property="currency" jdbcType="VARCHAR"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, order_id, line_no, account_id, amount, currency, created_at, updated_at
    </sql>

    <select id="selectByOrderId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM order_funding_line
        WHERE order_id = #{orderId}
        ORDER BY line_no ASC
    </select>

    <insert id="insert" parameterType="com.timelordtty.dca.model.OrderFundingLine" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO order_funding_line (
            order_id, line_no, account_id, amount, currency, created_at, updated_at
        ) VALUES (
            #{orderId}, #{lineNo}, #{accountId}, #{amount}, #{currency}, NOW(), NOW()
        )
    </insert>

    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO order_funding_line (
            order_id, line_no, account_id, amount, currency, created_at, updated_at
        ) VALUES
        <foreach collection="fundingLines" item="item" separator=",">
            (#{item.orderId}, #{item.lineNo}, #{item.accountId}, #{item.amount}, #{item.currency}, NOW(), NOW())
        </foreach>
    </insert>

    <delete id="deleteByOrderId">
        DELETE FROM order_funding_line
        WHERE order_id = #{orderId}
    </delete>

</mapper>
