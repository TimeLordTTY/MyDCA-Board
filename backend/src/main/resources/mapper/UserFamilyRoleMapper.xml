<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.timelordtty.dca.mapper.UserFamilyRoleMapper">

    <resultMap id="BaseResultMap" type="com.timelordtty.dca.model.UserFamilyRole">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="family_id" property="familyId"/>
        <result column="role" property="role"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT * FROM user_family_roles WHERE user_id = #{userId}
    </select>

    <select id="selectByFamilyId" resultMap="BaseResultMap">
        SELECT * FROM user_family_roles WHERE family_id = #{familyId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_family_roles (user_id, family_id, role, created_at, updated_at)
        VALUES (#{userId}, #{familyId}, #{role}, NOW(), NOW())
    </insert>

    <delete id="delete">
        DELETE FROM user_family_roles WHERE user_id = #{userId} AND family_id = #{familyId}
    </delete>

</mapper>

